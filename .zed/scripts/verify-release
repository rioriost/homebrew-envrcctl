#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "==> verify-release: start"

if [[ "$(uname -s)" == "Darwin" ]]; then
  echo "==> macOS: build auth helper"
  sh ./scripts/build_macos_auth_helper.sh
fi

if command -v uv >/dev/null 2>&1; then
  uv run python -m pytest --cov=envrcctl --cov-report=term-missing --cov-fail-under=95
  uv run bandit -r src -x tests -s B404,B603,B607
else
  python -m pytest --cov=envrcctl --cov-report=term-missing --cov-fail-under=95
  bandit -r src -x tests -s B404,B603,B607
fi

echo "==> verify-release: OK"
